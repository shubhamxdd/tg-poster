{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/webhook",
      "destination": "/api/index.js"
    },
    {
      "source": "/movie/:slug",
      "destination": "/api/og.js"
    },
    {
      "source": "/series/:slug",
      "destination": "/api/og.js"
    },
    {
      "source": "/anime/:slug",
      "destination": "/api/og.js"
    },
    {
      "source": "/((?!api|_next|favicon\\.svg|og-image\\.png|assets|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
